# Vagrantfile — RHEL-style lab datacenter
# Three AlmaLinux 9 VMs on a private network:
#   - server    (DNS + NTP)   192.168.56.10
#   - client-a                192.168.56.11
#   - client-b                192.168.56.12

Vagrant.configure("2") do |config|
  config.vm.box = "almalinux/9"

  # ---------- Server: DNS + NTP ----------
  config.vm.define "server" do |server|
    server.vm.hostname = "dns01.lab.local"
    server.vm.network "private_network", ip: "192.168.56.10"
    server.vm.provider "virtualbox" do |vb|
      vb.name   = "lab-server"
      vb.memory = 1024
      vb.cpus   = 1
    end
  end

  # ---------- Client A ----------
  config.vm.define "client-a" do |client|
    client.vm.hostname = "client01.lab.local"
    client.vm.network "private_network", ip: "192.168.56.11"
    client.vm.provider "virtualbox" do |vb|
      vb.name   = "lab-client-a"
      vb.memory = 512
      vb.cpus   = 1
    end
  end

  # ---------- Client B ----------
  config.vm.define "client-b" do |client|
    client.vm.hostname = "client02.lab.local"
    client.vm.network "private_network", ip: "192.168.56.12"
    client.vm.provider "virtualbox" do |vb|
      vb.name   = "lab-client-b"
      vb.memory = 512
      vb.cpus   = 1
    end
  end
end